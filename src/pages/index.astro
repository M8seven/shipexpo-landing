            </div>
            <div class="app-list-time">now</div>
            <div class="app-list-badge" id="ali-badge-1">3</div>
          </div>
          <div class="app-list-item" id="ali-2">
            <div class="app-list-avatar"></div>
            <div class="app-list-text">
              <div class="app-list-name">Payments</div>
              <div class="app-list-msg">stripe webhook received</div>
            </div>
            <div class="app-list-time">1m</div>
          </div>
          <div class="app-list-item" id="ali-3">
            <div class="app-list-avatar"></div>
            <div class="app-list-text">
              <div class="app-list-name">Notifications</div>
              <div class="app-list-msg">push registered: ok</div>
            </div>
            <div class="app-list-time">3m</div>
          </div>
          <div class="app-list-item" id="ali-4">
            <div class="app-list-avatar"></div>
            <div class="app-list-text">
              <div class="app-list-name">Deploy</div>
              <div class="app-list-msg">fly: v8 live</div>
            </div>
