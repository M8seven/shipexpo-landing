</footer>

<script is:inline>
(function() {
  'use strict';

  // ---- LENIS SMOOTH SCROLL (guarded: must never block the hero reveal) ----
  try {
    var lenis = new Lenis({
      duration: 1.1,
      easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
      smooth: true,
    });
    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(function(time) { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);
  } catch (e) { /* no smooth scroll, page still renders */ }

