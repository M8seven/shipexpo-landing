      </div>
    </div>
  </div>

  <!-- Phone mockup -->
  <div class="phone-frame-wrap" id="phone-frame-wrap">
    <div class="phone-frame" id="phone-frame">
      <div class="phone-notch"></div>
      <div class="phone-screen">
        <!-- Screen overlay: starts black, fades out when "lit" -->
        <div class="phone-screen-overlay off" id="phone-overlay"></div>

        <!-- App header -->
        <div class="app-header" id="app-header">
          <div class="app-header-logo">shipexpo</div>
          <div class="app-header-dot"></div>
        </div>

        <!-- Chat list -->
        <div class="app-list" id="app-list">
          <div class="app-list-item" id="ali-1">
            <div class="app-list-avatar accent"></div>
            <div class="app-list-text">
              <div class="app-list-name">General</div>
