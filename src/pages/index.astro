    <div class="phone-build-steps">
      <div class="build-step" id="bstep-1">
        <span class="build-step-num">01</span>
        <div class="build-step-text"><strong>npx create-shipexpo</strong> clones the working app</div>
      </div>
      <div class="build-step" id="bstep-2">
        <span class="build-step-num">02</span>
