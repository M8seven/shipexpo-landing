  // ---- MOSSA 4b: MAGNETIC BUTTONS ----
  try {
    var magnetBtns = document.querySelectorAll('[data-magnetic]');
    if (true) { // TODO pre-launch: ripristinare window.matchMedia prefers-reduced-motion
      magnetBtns.forEach(function(btn) {
        var bx = 0, by = 0;
        var tbx = 0, tby = 0;
        var animId;

        function animMag() {
          bx += (tbx - bx) * 0.14;
          by += (tby - by) * 0.14;
          btn.style.transform = 'translate(' + bx.toFixed(2) + 'px, ' + by.toFixed(2) + 'px)';
          if (Math.abs(tbx - bx) > 0.1 || Math.abs(tby - by) > 0.1) {
            animId = requestAnimationFrame(animMag);
          }
        }

        btn.addEventListener('mousemove', function(e) {
          var rect = btn.getBoundingClientRect();
          var relX = e.clientX - rect.left - rect.width / 2;
          var relY = e.clientY - rect.top  - rect.height / 2;
          tbx = relX * 0.32;
          tby = relY * 0.32;
          cancelAnimationFrame(animId);
          animId = requestAnimationFrame(animMag);
        });

        btn.addEventListener('mouseleave', function() {
          tbx = 0; tby = 0;
          cancelAnimationFrame(animId);
          animId = requestAnimationFrame(animMag);
        });
