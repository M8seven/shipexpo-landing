---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ShipExpo — Ship your app in hours, not weeks.">

<!-- Custom cursor -->
<div id="cursor"></div>
<div id="cursor-ring"></div>

<!-- Scroll progress sidebar -->
<div id="scroll-progress">
  <div class="progress-track">
    <div class="progress-fill" id="progress-fill"></div>
  </div>
  <div class="progress-steps">
    <div class="progress-step" data-section="hero">01</div>
    <div class="progress-step" data-section="code-section">02</div>
    <div class="progress-step" data-section="what-you-get">03</div>
    <div class="progress-step" data-section="phone-section">04</div>
    <div class="progress-step" data-section="cta">05</div>
  </div>
</div>

<!-- NAV -->
<nav id="main-nav">
  <div class="nav-logo">
    <div class="nav-logo-dot"></div>
    shipexpo
  </div>
  <ul class="nav-links">
    <li><a href="#code-section">Stack</a></li>
    <li><a href="#what-you-get">Includes</a></li>
    <li><a href="#cta">Pricing</a></li>
    <li><a href="#cta" class="nav-cta">$ get it &mdash; $99</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-left">
    <div class="hero-badge" id="hero-badge">
      <div class="hero-badge-line"></div>
      Expo + Node.js boilerplate
    </div>

    <h1 class="hero-h1">
      <span class="line-wrap"><span class="line-inner">Ship your app</span></span>
      <span class="line-wrap"><span class="line-inner">in hours,</span></span>
      <span class="line-wrap"><span class="line-inner"><em>not weeks.</em></span></span>
    </h1>

    <p class="hero-sub" id="hero-sub">
      Auth, payments, push notifications, chat, and production deploy &mdash; wired up and working on day one. Every week you spend on setup is a week you're not shipping.
    </p>

    <div class="hero-actions" id="hero-actions">
      <a href="#cta" class="btn-primary" data-magnetic>
        Get ShipExpo
      </a>
      <div class="btn-price">
        <strong>$99</strong>
        <span>one-time, no subscription</span>
      </div>
    </div>
  </div>

  <div class="hero-right" id="hero-terminal">
    <!-- Mossa 1: glow vivo -->
    <div class="terminal-glow" id="terminal-glow"></div>
    <div class="terminal-window">
      <div class="terminal-titlebar">
        <div class="terminal-dots">
          <div class="terminal-dot dot-red"></div>
          <div class="terminal-dot dot-yellow"></div>
          <div class="terminal-dot dot-green"></div>
        </div>
        <div class="terminal-title">bash &mdash; ~/projects</div>
      </div>
      <div class="terminal-body" id="terminal-body">
        <!-- Lines injected by JS -->
      </div>
    </div>
  </div>
</section>

<!-- SECTION DIVIDER -->
<div class="section-divider">
  <div class="section-divider-line"></div>
  <div class="section-divider-label">What's inside</div>
  <div class="section-divider-line"></div>
</div>

<!-- CODE SECTION -->
<section id="code-section">
  <div class="code-header" id="code-header">
    <div class="scroll-step-label" id="step-02">
      <span class="step-num">02</span>
      <span class="step-line"></span>
      real code, no magic
    </div>
    <div class="code-header-label">No abstractions, no vendor lock-in</div>
    <h2>The boring parts, <em>done right.</em></h2>
    <p>Every pattern you'd write anyway. Every gotcha already handled. Code you own, no magic classes.</p>
  </div>

  <div class="code-tabs" id="code-tabs">
    <button class="code-tab active" data-tab="express">server/auth.ts</button>
    <button class="code-tab" data-tab="expo">hooks/useAuth.ts</button>
    <button class="code-tab" data-tab="package">package.json</button>
  </div>

  <div class="code-panels" id="code-panels">

    <!-- Express auth route -->
    <div class="code-panel active" data-panel="express">
      <div class="code-block-outer" id="beam-block">
        <div class="code-block-inner">
          <div class="code-block-titlebar">
            <div class="code-file-name">server/auth.ts</div>
            <div class="code-lang-badge">TypeScript</div>
          </div>
          <pre><span class="cm">// JWT refresh + device token rotation</span>
<span class="kw">import</span> <span class="pu">{</span> <span class="var">Router</span><span class="pu">,</span> <span class="var">Request</span><span class="pu">,</span> <span class="var">Response</span> <span class="pu">}</span> <span class="kw">from</span> <span class="str">'express'</span>
<span class="kw">import</span> <span class="pu">{</span> <span class="fn">signAccess</span><span class="pu">,</span> <span class="fn">signRefresh</span><span class="pu">,</span> <span class="fn">verify</span> <span class="pu">}</span> <span class="kw">from</span> <span class="str">'../lib/jwt'</span>
<span class="kw">import</span> <span class="pu">{</span> <span class="var">db</span> <span class="pu">}</span> <span class="kw">from</span> <span class="str">'../lib/db'</span>

<span class="kw">const</span> <span class="var">router</span> <span class="pu">=</span> <span class="fn">Router</span><span class="pu">()</span>

<span class="var">router</span><span class="pu">.</span><span class="fn">post</span><span class="pu">(</span><span class="str">'/refresh'</span><span class="pu">,</span> <span class="kw">async</span> <span class="pu">(</span><span class="var">req</span><span class="pu">:</span> <span class="var">Request</span><span class="pu">,</span> <span class="var">res</span><span class="pu">:</span> <span class="var">Response</span><span class="pu">)</span> <span class="pu">=&gt;</span> <span class="pu">{</span>
  <span class="kw">const</span> <span class="pu">{</span> <span class="prop">token</span> <span class="pu">}</span> <span class="pu">=</span> <span class="var">req</span><span class="pu">.</span><span class="prop">body</span>
  <span class="kw">const</span> <span class="var">payload</span> <span class="pu">=</span> <span class="kw">await</span> <span class="fn">verify</span><span class="pu">(</span><span class="var">token</span><span class="pu">,</span> <span class="str">'refresh'</span><span class="pu">)</span>

  <span class="cm">// rotation: old token is invalidated on use</span>
  <span class="kw">await</span> <span class="var">db</span><span class="pu">.</span><span class="prop">refreshToken</span><span class="pu">.</span><span class="fn">delete</span><span class="pu">({</span> <span class="prop">where</span><span class="pu">:</span> <span class="pu">{</span> <span class="prop">token</span> <span class="pu">}</span> <span class="pu">})</span>
  <span class="kw">const</span> <span class="var">next</span> <span class="pu">=</span> <span class="kw">await</span> <span class="fn">signRefresh</span><span class="pu">(</span><span class="var">payload</span><span class="pu">.</span><span class="prop">userId</span><span class="pu">)</span>

  <span class="var">res</span><span class="pu">.</span><span class="fn">json</span><span class="pu">({</span>
    <span class="prop">access</span><span class="pu">:</span>   <span class="kw">await</span> <span class="fn">signAccess</span><span class="pu">(</span><span class="var">payload</span><span class="pu">.</span><span class="prop">userId</span><span class="pu">),</span>
    <span class="prop">refresh</span><span class="pu">:</span>  <span class="var">next</span><span class="pu">,</span>
  <span class="pu">})</span>
<span class="pu">})</span>

<span class="kw">export default</span> <span class="var">router</span></pre>
        </div>
      </div>
    </div>

    <!-- Expo hook -->
    <div class="code-panel" data-panel="expo">
      <div class="code-block-outer">
        <div class="code-block-inner">
          <div class="code-block-titlebar">
            <div class="code-file-name">hooks/useAuth.ts</div>
            <div class="code-lang-badge">TypeScript</div>
          </div>
          <pre><span class="cm">// Secure token storage via expo-secure-store</span>
<span class="kw">import</span> <span class="pu">{</span> <span class="fn">useState</span><span class="pu">,</span> <span class="fn">useEffect</span><span class="pu">,</span> <span class="fn">useCallback</span> <span class="pu">}</span> <span class="kw">from</span> <span class="str">'react'</span>
<span class="kw">import</span> <span class="pu">*</span> <span class="kw">as</span> <span class="var">SecureStore</span> <span class="kw">from</span> <span class="str">'expo-secure-store'</span>
<span class="kw">import</span> <span class="pu">{</span> <span class="var">api</span> <span class="pu">}</span> <span class="kw">from</span> <span class="str">'../lib/api'</span>

<span class="kw">export function</span> <span class="fn">useAuth</span><span class="pu">()</span> <span class="pu">{</span>
  <span class="kw">const</span> <span class="pu">[</span><span class="var">user</span><span class="pu">,</span> <span class="fn">setUser</span><span class="pu">]</span> <span class="pu">=</span> <span class="fn">useState</span><span class="pu">&lt;</span><span class="var">User</span> <span class="pu">|</span> <span class="kw">null</span><span class="pu">&gt;(</span><span class="kw">null</span><span class="pu">)</span>

  <span class="fn">useEffect</span><span class="pu">(() =&gt;</span> <span class="pu">{</span>
    <span class="var">SecureStore</span><span class="pu">.</span><span class="fn">getItemAsync</span><span class="pu">(</span><span class="str">'access_token'</span><span class="pu">)</span>
      <span class="pu">.</span><span class="fn">then</span><span class="pu">(</span><span class="var">token</span> <span class="pu">=&gt;</span> <span class="var">token</span> <span class="pu">&amp;&amp;</span> <span class="var">api</span><span class="pu">.</span><span class="fn">me</span><span class="pu">(</span><span class="var">token</span><span class="pu">))</span>
      <span class="pu">.</span><span class="fn">then</span><span class="pu">(</span><span class="fn">setUser</span><span class="pu">)</span>
  <span class="pu">},</span> <span class="pu">[])</span>

  <span class="kw">const</span> <span class="fn">signOut</span> <span class="pu">=</span> <span class="fn">useCallback</span><span class="pu">(</span><span class="kw">async</span> <span class="pu">() =&gt;</span> <span class="pu">{</span>
    <span class="kw">await</span> <span class="var">SecureStore</span><span class="pu">.</span><span class="fn">deleteItemAsync</span><span class="pu">(</span><span class="str">'access_token'</span><span class="pu">)</span>
    <span class="kw">await</span> <span class="var">SecureStore</span><span class="pu">.</span><span class="fn">deleteItemAsync</span><span class="pu">(</span><span class="str">'refresh_token'</span><span class="pu">)</span>
    <span class="fn">setUser</span><span class="pu">(</span><span class="kw">null</span><span class="pu">)</span>
  <span class="pu">},</span> <span class="pu">[])</span>

  <span class="kw">return</span> <span class="pu">{</span> <span class="prop">user</span><span class="pu">,</span> <span class="fn">signOut</span> <span class="pu">}</span>
<span class="pu">}</span></pre>
        </div>
      </div>
    </div>

    <!-- package.json -->
    <div class="code-panel" data-panel="package">
      <div class="code-block-outer">
        <div class="code-block-inner">
          <div class="code-block-titlebar">
            <div class="code-file-name">package.json</div>
            <div class="code-lang-badge">JSON</div>
          </div>
          <pre><span class="pu">{</span>
  <span class="prop">"name"</span><span class="pu">:</span>        <span class="str">"my-app"</span><span class="pu">,</span>
  <span class="prop">"version"</span><span class="pu">:</span>     <span class="str">"1.0.0"</span><span class="pu">,</span>
  <span class="prop">"dependencies"</span><span class="pu">:</span> <span class="pu">{</span>
    <span class="prop">"expo"</span><span class="pu">:</span>                      <span class="str">"~52.0.0"</span><span class="pu">,</span>
    <span class="prop">"expo-router"</span><span class="pu">:</span>              <span class="str">"~4.0.0"</span><span class="pu">,</span>
    <span class="prop">"expo-secure-store"</span><span class="pu">:</span>        <span class="str">"~14.0.0"</span><span class="pu">,</span>
    <span class="prop">"expo-notifications"</span><span class="pu">:</span>       <span class="str">"~0.29.0"</span><span class="pu">,</span>
    <span class="prop">"stripe"</span><span class="pu">:</span>                    <span class="str">"^16.0.0"</span><span class="pu">,</span>
    <span class="prop">"@stripe/stripe-react-native"</span><span class="pu">:</span> <span class="str">"0.39.0"</span><span class="pu">,</span>
    <span class="cm">// server</span>
    <span class="prop">"express"</span><span class="pu">:</span>                   <span class="str">"^4.21.0"</span><span class="pu">,</span>
    <span class="prop">"@prisma/client"</span><span class="pu">:</span>            <span class="str">"^6.0.0"</span><span class="pu">,</span>
    <span class="prop">"socket.io"</span><span class="pu">:</span>                 <span class="str">"^4.8.0"</span><span class="pu">,</span>
    <span class="prop">"jsonwebtoken"</span><span class="pu">:</span>              <span class="str">"^9.0.0"</span>
  <span class="pu">},</span>
  <span class="prop">"scripts"</span><span class="pu">:</span> <span class="pu">{</span>
    <span class="prop">"dev"</span><span class="pu">:</span>     <span class="str">"concurrently \"expo start\" \"npm run server\""</span><span class="pu">,</span>
    <span class="prop">"server"</span><span class="pu">:</span>  <span class="str">"tsx watch server/index.ts"</span><span class="pu">,</span>
    <span class="prop">"deploy"</span><span class="pu">:</span>  <span class="str">"eas build --platform all &amp;&amp; fly deploy"</span>
  <span class="pu">}</span>
<span class="pu">}</span></pre>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- STATS STRIP -->
<div id="stats-strip">
  <div class="stats-inner">
    <div class="stat-item">
      <div class="stat-number"><span>~</span>3h</div>
      <div class="stat-label">From clone to first production deploy</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">6<span>+</span></div>
      <div class="stat-label">Core modules wired and tested</div>
    </div>
    <div class="stat-item">
      <div class="stat-number"><span>0</span></div>
      <div class="stat-label">Vendor lock-in. Your code, your infrastructure</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">$<span>99</span></div>
      <div class="stat-label">Once. No monthly fee. No seat limits</div>
    </div>
  </div>
</div>

<!-- WHAT YOU GET -->
<section id="what-you-get">
  <div class="wyg-header" id="wyg-header">
    <div class="scroll-step-label" id="step-03">
      <span class="step-num">03</span>
      <span class="step-line"></span>
      what ships with it
    </div>
    <div class="wyg-header-label">Everything included</div>
    <h2>No assembly required.</h2>
  </div>

  <div class="wyg-grid">
    <div class="wyg-item">
      <div class="wyg-item-tag">auth</div>
      <h3>JWT + refresh rotation</h3>
      <p>Secure token storage on device, server-side session management, device tracking, password reset flow.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">expo-secure-store</span>
        <span class="stack-tag">express</span>
        <span class="stack-tag">prisma</span>
      </div>
    </div>
    <div class="wyg-item">
      <div class="wyg-item-tag">payments</div>
      <h3>Stripe subscriptions</h3>
      <p>One-time and recurring payments, webhook handling, entitlement gating, Stripe Customer Portal.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">stripe</span>
        <span class="stack-tag">stripe-react-native</span>
      </div>
    </div>
    <div class="wyg-item">
      <div class="wyg-item-tag">push</div>
      <h3>Push notifications</h3>
      <p>Expo push + FCM/APNs fallback, per-user topic subscriptions, server-side send utilities.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">expo-notifications</span>
        <span class="stack-tag">expo-push-service</span>
      </div>
    </div>
    <div class="wyg-item">
      <div class="wyg-item-tag">realtime</div>
      <h3>Chat + live data</h3>
      <p>Socket.io rooms, message persistence, typing indicators, presence. Drop your own domain logic on top.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">socket.io</span>
        <span class="stack-tag">redis</span>
      </div>
    </div>
    <div class="wyg-item">
      <div class="wyg-item-tag">deploy</div>
      <h3>One-command deploy</h3>
      <p>EAS build for iOS + Android. Fly.io config for the server. GitHub Actions CI. Docker-ready.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">eas</span>
        <span class="stack-tag">fly.io</span>
        <span class="stack-tag">docker</span>
      </div>
    </div>
    <div class="wyg-item">
      <div class="wyg-item-tag">dx</div>
      <h3>Dev toolchain</h3>
      <p>TypeScript end-to-end, Prettier + ESLint, env validation with zod, shared types client/server.</p>
      <div class="wyg-item-stack">
        <span class="stack-tag">typescript</span>
        <span class="stack-tag">zod</span>
        <span class="stack-tag">tsx</span>
      </div>
    </div>
  </div>
</section>

<!-- PHONE SECTION -->
<div class="section-divider">
  <div class="section-divider-line"></div>
  <div class="section-divider-label">The output</div>
  <div class="section-divider-line"></div>
</div>

<section id="phone-section">
  <div class="phone-copy" id="phone-copy">
    <div class="scroll-step-label" id="step-04">
      <span class="step-num">04</span>
      <span class="step-line"></span>
      code becomes product
    </div>
    <div class="phone-copy-label">From terminal to screen</div>
