      tab.classList.add('active');
      var target = tab.getAttribute('data-tab');
      var panel = document.querySelector('[data-panel="' + target + '"]');
      if (panel) {
        panel.classList.add('active');
        var outerBlock = panel.querySelector('.code-block-outer');
        if (outerBlock) {
