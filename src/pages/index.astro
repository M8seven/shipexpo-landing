  ];

  var CHAR_DELAY_CMD = 45;
  var LOOP_PAUSE = 2800;

  function clearTerminal() {
    terminalBody.innerHTML = '';
  }

  function makeLineEl(type, text, note) {
    var div = document.createElement('div');
    div.classList.add('terminal-line');

    if (type === 'cmd') {
      var ps = document.createElement('span');
      ps.className = 'prompt-sym';
      ps.textContent = '>';
      div.appendChild(ps);
      var txt = document.createElement('span');
      txt.className = 'term-text';
      div.appendChild(txt);
      return { el: div, textSpan: txt };
    }

    if (type === 'ok') {
      var row = document.createElement('span');
      row.className = 'term-output';
      row.style.display = 'flex';
      row.style.width = '100%';
      row.style.alignItems = 'baseline';
      row.style.gap = '12px';
      var mark = document.createElement('span');
      mark.className = 'term-ok';
      mark.textContent = '  ok';
      var label = document.createElement('span');
      label.style.color = 'var(--text)';
      label.textContent = text;
      row.appendChild(mark);
      row.appendChild(label);
      if (note) {
        var nt = document.createElement('span');
        nt.style.color = 'var(--muted)';
        nt.style.marginLeft = 'auto';
        nt.style.whiteSpace = 'nowrap';
        nt.textContent = 'normally ' + note;
        row.appendChild(nt);
      }
      div.appendChild(row);
      return { el: div, textSpan: null };
    }

    if (type === 'dim') {
      var sp2 = document.createElement('span');
      sp2.className = 'term-output term-dim';
      sp2.textContent = '  ' + text;
      div.appendChild(sp2);
      return { el: div, textSpan: null };
    }

    if (type === 'ready') {
      var row2 = document.createElement('span');
      row2.className = 'term-output';
      row2.style.display = 'flex';
      row2.style.width = '100%';
      row2.style.alignItems = 'baseline';
      row2.style.gap = '12px';
      var sp3 = document.createElement('span');
      sp3.className = 'term-ok';
      sp3.style.fontWeight = '500';
      sp3.textContent = '  ' + text;
      row2.appendChild(sp3);
      if (note) {
        var nt2 = document.createElement('span');
        nt2.style.color = 'var(--accent)';
        nt2.style.marginLeft = 'auto';
        nt2.style.fontWeight = '500';
        nt2.style.whiteSpace = 'nowrap';
        nt2.textContent = note;
        row2.appendChild(nt2);
      }
      var cursor = document.createElement('span');
      cursor.className = 'cursor-blink';
      row2.appendChild(cursor);
      div.appendChild(row2);
      return { el: div, textSpan: null };
    }

    // 'out'
    var sp4 = document.createElement('span');
    sp4.className = 'term-output';
    sp4.textContent = text ? '  ' + text : '';
    div.appendChild(sp4);
    return { el: div, textSpan: null };
  }

  function typeText(span, text, charDelay, done) {
    var i = 0;
    var cursor = document.createElement('span');
    cursor.className = 'cursor-blink';
    span.parentNode.appendChild(cursor);

    function step() {
      if (i < text.length) {
        span.textContent += text[i];
        i++;
        setTimeout(step, charDelay + (Math.random() * 20 - 10));
      } else {
        cursor.remove();
        if (done) done();
      }
    }
    step();
  }

  function runScript(lines, idx, onDone) {
    if (idx >= lines.length) {
      if (onDone) onDone();
      return;
    }

    var step = lines[idx];
    var built = makeLineEl(step.type, step.text, step.note);
    terminalBody.appendChild(built.el);

    terminalBody.scrollTop = terminalBody.scrollHeight;

    function next() {
      var d = step.delay || 60;
      setTimeout(function() {
        runScript(lines, idx + 1, onDone);
      }, d);
    }

    if (step.type === 'cmd' && built.textSpan) {
      setTimeout(function() {
        typeText(built.textSpan, step.text, CHAR_DELAY_CMD, next);
      }, 60);
    } else {
      next();
    }
  }

  function loopTerminal() {
    clearTerminal();
    runScript(SCRIPT, 0, function() {
      setTimeout(loopTerminal, LOOP_PAUSE);
    });
  }

  setTimeout(loopTerminal, 1200);

