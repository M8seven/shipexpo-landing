        phonePinTl.to('#ali-4',      { opacity: 1, x: 0,  duration: 0.12, ease: 'power2.out' }, 0.80);
        phonePinTl.to('#app-bottom', { opacity: 1, y: 0,  duration: 0.12, ease: 'power2.out' }, 0.84);
        phonePinTl.to('#app-btn',    { opacity: 1,         duration: 0.10, ease: 'power2.out' }, 0.88);
        phonePinTl.to('#ali-badge-1',{ opacity: 1, scale: 1, duration: 0.12, ease: 'back.out(2)' }, 0.93);
      }
    } catch(e) { /* phone pin failed silently */ }

    // ---- CTA (bidirezionale) ----
    try {
      gsap.set('#cta-inner', { opacity: 0, y: 30 });
      ScrollTrigger.create({
        trigger: '#cta-inner',
        start: 'top 80%',
        end: 'top 15%',
        onEnter:     function() { gsap.to('#cta-inner', { opacity: 1, y: 0,  duration: 0.8, ease: 'power2.out' }); },
        onLeaveBack: function() { gsap.to('#cta-inner', { opacity: 0, y: 30, duration: 0.5, ease: 'power2.in' }); },
      });
      revealStepLabel('step-05', '#cta-inner');
    } catch(e) {}

  } // end !prefersReduced

  // ---- SCROLL TRIGGER REFRESH (dopo setup) ----
  try { ScrollTrigger.refresh(); } catch(e) {}

})();
</script>

</BaseLayout>
