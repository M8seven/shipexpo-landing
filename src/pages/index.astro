  // ---- MOSSA 1: GLOW MOUSE TRACKING ----
  try {
    var glowEl = document.getElementById('terminal-glow');
    var heroTerminal = document.getElementById('hero-terminal');

    if (glowEl && heroTerminal) {
      var glowX = 50, glowY = 50;
      var targetX = 50, targetY = 50;
      var glowActive = false;

      heroTerminal.addEventListener('mouseenter', function() { glowActive = true; });
      heroTerminal.addEventListener('mouseleave', function() {
        glowActive = false;
        targetX = 50; targetY = 50;
      });

      document.addEventListener('mousemove', function(e) {
        if (!glowActive) return;
        var rect = heroTerminal.getBoundingClientRect();
        targetX = ((e.clientX - rect.left) / rect.width) * 100;
        targetY = ((e.clientY - rect.top) / rect.height) * 100;
      }, { passive: true });

      function animateGlow() {
        // lerp toward target
        glowX += (targetX - glowX) * 0.08;
        glowY += (targetY - glowY) * 0.08;
        glowEl.style.background =
          'radial-gradient(ellipse 70% 60% at ' + glowX.toFixed(1) + '% ' + glowY.toFixed(1) + '%, ' +
          'rgba(0, 217, 126, 0.22) 0%, rgba(0, 217, 126, 0.08) 40%, transparent 75%)';
        requestAnimationFrame(animateGlow);
      }
      requestAnimationFrame(animateGlow);
    }
  } catch(e) { /* glow mouse tracking failed silently */ }

